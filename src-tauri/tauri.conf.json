{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenPet",
  "version": "0.1.6",
  "identifier": "dev.xter.openpet",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:15373",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "OpenPet Settings",
        "url": "/?window=settings",
        "width": 780,
        "height": 760,
        "minWidth": 560,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "pet",
        "title": "OpenPet",
        "url": "/?window=pet",
        "width": 320,
        "height": 320,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* http://[::1]:* ws://127.0.0.1:15373; img-src 'self' asset: http://asset.localhost https://asset.localhost http://127.0.0.1:* http://localhost:* http://[::1]:* data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "resources": {
      "../skills/": "skills/"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCQkM0MjkxRkM0RTIyQTcKUldTbklrNzhrVUs4ZTk1YkQxMll3OEJ3bk54RHVnYStNZnBZTUVac2E5QUlSMnNKTG9aSDQrM1AK",
      "endpoints": [
        "https://github.com/X-T-E-R/OpenPet/releases/latest/download/latest.json"
      ]
    }
  }
}
